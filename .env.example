# ── Cloudflare R2 (the data store — replaces a database) ───────────────────
# Create an R2 bucket named e.g. "officialreq" in the Cloudflare dashboard,
# then create an R2 API token (S3-compatible). Fill these in:
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET=officialreq
# Optional: public R2 dev/custom-domain URL used to read config client-side.
# If set, the runtime config is read directly from R2; otherwise it's served
# via /api/config. Example: https://pub-xxxx.r2.dev  or  https://cdn.yoursite.com
R2_PUBLIC_BASE_URL=

# ── Admin auth (Auth.js / NextAuth — single-admin Google OAuth) ────────────
# Sign in at /ops/login. ONLY the Google account whose verified email equals
# ADMIN_EMAIL may access the console.
# AUTH_SECRET: generate with `npx auth secret` (or `openssl rand -base64 32`).
# Create an OAuth 2.0 Web client at https://console.cloud.google.com/apis/credentials
# Authorised redirect URI (local): http://localhost:3000/api/auth/callback/google
# Production: https://officialrequirements.com/api/auth/callback/google
AUTH_SECRET=change-me-generate-a-secret
AUTH_GOOGLE_ID=your-google-oauth-client-id
AUTH_GOOGLE_SECRET=your-google-oauth-client-secret
ADMIN_EMAIL=you@example.com

# ── Vercel deploy hook (the admin "Rebuild" button + auto-rebuild) ─────────
# Project Settings → Git → Deploy Hooks → create one, paste the URL here.
VERCEL_DEPLOY_HOOK_URL=

# ── Cron secret (secures the self-maintaining freshness jobs) ──────────────
# Set a long random value. Vercel Cron sends it as a Bearer token; the admin
# "Run now" buttons pass it too. Without it, cron routes are dev-only.
CRON_SECRET=another-long-random-string

# ── Analytics / search ─────────────────────────────────────────────────────
NEXT_PUBLIC_GA4_ID=
NEXT_PUBLIC_SITE_URL=https://officialrequirements.com

# ── Author / E-E-A-T ───────────────────────────────────────────────────────
# A named, credentialed human author is the strongest YMYL trust signal. Set
# these to put a real person on the byline + author schema + /about. Leave blank
# to fall back to the editorial-team organization.
AUTHOR_NAME=
AUTHOR_URL=
AUTHOR_BIO=

# ── Google Search Console (feeds the admin SEO dashboard) ──────────────────
# Service account JSON key (the entire JSON on one line), OR store it in R2 at
# credentials/gsc-sa.json and leave this blank.
GSC_SERVICE_ACCOUNT_JSON=
# Your verified property: "sc-domain:officialrequirements.com" or a URL prefix
# like "https://officialrequirements.com/". Add the service-account email as a
# user on the property in Search Console → Settings → Users.
GSC_SITE_URL=

# ── Core Web Vitals (Chrome UX Report field data, shown in admin SEO) ──────
# Enable the "Chrome UX Report API" in Google Cloud, create an API key, paste here.
# Vercel Web Analytics + Speed Insights need no key — they're enabled by the
# components in the layout and viewable in the Vercel dashboard.
CRUX_API_KEY=

# ── Self-healing crawler (optional headless render fallback) ────────────────
# The crawler reads static HTML, JSON APIs, and SPA-embedded data on its own.
# For the rare fully client-rendered page with no embedded data, set a render
# service that returns rendered HTML (e.g. a Browserless instance). Use {url}
# as a placeholder, or it appends ?url=. Leave blank to skip the fallback.
RENDER_SERVICE_URL=

# ── IndexNow (instant indexing for Bing / Yandex / IndexNow) ───────────────
# Generate a random key (e.g. a UUID without dashes) and paste it here. It's
# served at /api/indexnow-key and used to ping search engines when pages change.
INDEXNOW_KEY=
