{
  "name": "officialrequirements",
  "version": "0.1.0",
  "private": true,
  "description": "Programmatic SEO site for visa, university admission, and scholarship requirements. Static Next.js + Cloudflare R2 data layer. Affiliate-first.",
  "scripts": {
    "dev": "NODE_OPTIONS=--dns-result-order=ipv4first next dev",
    "build": "NODE_OPTIONS=--max-old-space-size=4096 next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "node --experimental-strip-types --test tests/*.test.ts",
    "seed:r2": "node scripts/seed-r2.mjs",
    "audit": "node scripts/audit-coverage.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "next": "^16.2.9",
    "next-auth": "^5.0.0-beta.31",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.39",
    "tailwindcss": "^3.4.6",
    "typescript": "^5.5.3"
  },
  "engines": {
    "node": ">=20.9.0"
  },
  "browserslist": [
    "chrome >= 109",
    "edge >= 109",
    "firefox >= 115",
    "safari >= 16",
    "ios_saf >= 16"
  ]
}
